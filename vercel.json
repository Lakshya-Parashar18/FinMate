{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "server/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/Client/$1"
    }
  ],
  "redirects": [
    {
      "source": "/Client/(.*)",
      "destination": "/$1",
      "permanent": true
    }
  ]
}
